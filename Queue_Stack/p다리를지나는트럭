from collections import deque

def solution(bridge_length, weight, truck_weights):
    answer = 0
    
    move_trucks = deque([])
    truck_weights = deque(truck_weights)
    
    sec = 0

    sum_weight = 0

    while True :
        sec += 1
        
        #기존 트럭 움직임
        for i, [loc, w] in enumerate(move_trucks) :
            if loc+1>bridge_length :
                sum_weight -= w
                move_trucks.pop()
                break
            else :
                move_trucks[i] = [loc+1,w]

        if truck_weights :
            w = truck_weights[0]
            if sum_weight + w <= weight :
                truck_weights.popleft()
                move_trucks.appendleft([1,w])
                sum_weight += w

        if not move_trucks and not truck_weights :
            return sec
    
    return answer

solution(2,10,[7,4,5,6])