from collections import deque

def solution(priorities, location):
    answer = 0

    arr = deque(enumerate(priorities))

    answer = 1

    while True :
        NUM, MAX = max(arr, key = lambda x : x[1])

        if location == NUM :
            return answer
        else : 
            answer += 1

        while arr :
            n,m = arr.popleft()

            if NUM != n :
                arr.append([n,m])
            else : 
                break
            



    return answer

solution([1, 1, 9, 1, 1, 1],0)