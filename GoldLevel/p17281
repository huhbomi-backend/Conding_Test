from itertools import permutations
from collections import deque

def play(n, players) :
    global result

    q = deque([-1,-1,-1])
    players = deque(players)

    out = 0
    sco = 0

    while out<3 :
        player = players.popleft()

        ball = result[n][player]

        if ball == 0 :
            out += 1
        else : 
            q.append(player)
            for _ in range(ball-1) :
                q.append(-1)
            for _ in range(ball) :
                IN = q.popleft()
                if IN >-1 :
                    sco += 1

        players.append(player)

    return sco, players

ans = 0 
N = int(input())
result = []

for _ in range(N) :
    arr = list(map(int, input().split()))
    result.append(arr)

orders = permutations(list(range(1,9)), 8)

for order in orders :
    order = list(order)
    order = order[0:3]+[0]+order[3:]
    
    score = 0 
    players = order.copy()
    for _ in range(N) :
        sco, players = play(_, players)
        score+=sco
    ans = max(ans,score)
    
print(ans)